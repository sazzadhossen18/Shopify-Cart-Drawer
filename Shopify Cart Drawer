<script>
  document.addEventListener("DOMContentLoaded", function () {
    const cartDrawer = document.getElementById("minicart");

    function openCartDrawer() {
      document.body.classList.add("minicart__open");
    }

    function closeCartDrawer() {
      document.body.classList.remove("minicart__open");
    }

    // ✅ Update cart count badge
    function updateCartCount(count) {
      const badge = document.querySelector(".cart-count-badge");
      if (badge) {
        badge.textContent = count;
      }
    }

    // ✅ Fetch latest count
    function fetchAndUpdateCartCount() {
      fetch("/cart.js")
        .then(res => res.json())
        .then(cart => {
          updateCartCount(cart.item_count);
        });
    }

    // ✅ Add to cart
    const addToCartForm = document.querySelector('form[action$="/cart/add"]');
    if (addToCartForm) {
      addToCartForm.addEventListener("submit", function (e) {
        e.preventDefault();
        const formData = new FormData(addToCartForm);

        fetch("/cart/add.js", {
          method: "POST",
          body: formData,
        })
          .then((res) => res.json())
          .then(() => {
            refreshCartDrawer();
            fetchAndUpdateCartCount();
          })
          .catch((error) => console.error("Add to cart error:", error));
      });
    }

    // ✅ Update quantity
    function updateQuantity(key, quantity) {
      fetch("/cart/change.js", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id: key, quantity: quantity }),
      })
        .then((res) => res.json())
        .then(() => {
          refreshCartDrawer();
          fetchAndUpdateCartCount();
        });
    }

    // ✅ Refresh minicart
    function refreshCartDrawer() {
      fetch("/?section_id=cart-drawer")
        .then((res) => res.text())
        .then((html) => {
          const tempDiv = document.createElement("div");
          tempDiv.innerHTML = html;
          const newMinicart = tempDiv.querySelector("#minicart");
          const currentMinicart = document.getElementById("minicart");

          if (newMinicart && currentMinicart) {
            currentMinicart.innerHTML = newMinicart.innerHTML;
            document.body.classList.add("minicart__open");
            bindCartDrawerEvents();
          }
        });
    }

    // ✅ Bind drawer events
    function bindCartDrawerEvents() {
      const overlay = cartDrawer.querySelector(".minicart__underlay");
      const closeBtn = cartDrawer.querySelector(".minicart__close-button");

      overlay?.addEventListener("click", closeCartDrawer);
      closeBtn?.addEventListener("click", closeCartDrawer);

      cartDrawer.querySelectorAll(".minicart__item").forEach((item) => {
        const key = item.dataset.key;
        const input = item.querySelector(".quantity-selector__input");

        item.querySelector(".quantity-selector__btn--inc")?.addEventListener("click", () => {
          const current = parseInt(input.value);
          updateQuantity(key, current + 1);
        });

        item.querySelector(".quantity-selector__btn--dec")?.addEventListener("click", () => {
          const current = parseInt(input.value);
          updateQuantity(key, Math.max(0, current - 1));
        });

        item.querySelector(".minicart__item-remove")?.addEventListener("click", () => {
          updateQuantity(key, 0);
        });

        let debounceTimer;
        input?.addEventListener("input", () => {
          clearTimeout(debounceTimer);
          debounceTimer = setTimeout(() => {
            const value = parseInt(input.value);
            if (!isNaN(value) && value >= 0) {
              updateQuantity(key, value);
            }
          }, 400);
        });
      });
    }

    // Initial bind
    bindCartDrawerEvents();

    // ✅ Click on cart icon opens drawer
    document.querySelectorAll('a[href="/cart"]').forEach((a) => {
      a.addEventListener("click", (e) => {
        e.preventDefault();
        openCartDrawer();
      });
    });

    // ✅ Initial cart count
    fetchAndUpdateCartCount();
  });
</script>




































